# Placeholder-only local environment template.
# Do not put real secrets in this file.

APP_ENV=local
SERVICE_NAME=salesops-workflow-automation-hub
MOCK_MODE=true

# Planned database URL for future Docker/PostgreSQL setup.
# Placeholder only; replace in a local ignored .env when the backend exists.
DATABASE_URL=postgresql+psycopg://salesops_user:placeholder_password@localhost:5432/salesops_local

# Integration mode defaults. Real providers require explicit approval.
CRM_PROVIDER=mock
SLACK_PROVIDER=mock
GOOGLE_SHEETS_PROVIDER=disabled

# Optional future CRM placeholders. Not real secrets.
CRM_BASE_URL=https://example.invalid/mock-crm
CRM_API_TOKEN=placeholder-not-a-real-secret
HUBSPOT_PRIVATE_APP_TOKEN=placeholder-not-a-real-secret

# Optional future Slack placeholders. Not real secrets.
SLACK_WEBHOOK_URL=https://example.invalid/not-a-real-webhook
SLACK_CHANNEL=#mock-salesops-alerts

# Demo behavior placeholders.
DEFAULT_LEAD_SOURCE=demo_form
DEFAULT_TIMEZONE=Europe/Kiev
